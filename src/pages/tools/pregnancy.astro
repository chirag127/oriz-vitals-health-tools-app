---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Pregnancy Due Date — Oriz Vitals" description="Estimate your pregnancy due date with Naegele's rule. Runs entirely in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Pregnancy Due Date</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="privacy mono">All calculations run in your browser. Nothing is sent to any server.</p>
    <p class="lede">Estimate based on the first day of your last menstrual period (LMP) using Naegele's rule: LMP + 280 days. Adjust if your cycle length is not 28 days.</p>

    <form class="calc-form" id="preg-form" novalidate>
      <div class="field">
        <label for="lmp">First day of last menstrual period (LMP)</label>
        <input type="date" id="lmp" name="lmp" required />
      </div>
      <div class="field">
        <label for="cycle">Cycle length (days)</label>
        <input type="number" id="cycle" name="cycle" min="20" max="45" step="1" value="28" required />
      </div>
      <button type="submit" class="btn">Estimate Due Date</button>
      <p class="err mono" id="err" role="alert"></p>
    </form>

    <div class="result hidden" id="preg-result" aria-live="polite">
      <div class="result-main">
        <span class="result-label mono">Estimated due date</span>
        <span class="result-value" id="due-date">—</span>
      </div>
      <div class="result-details">
        <p><span class="mono">Conception (approx):</span> <span id="conception">—</span></p>
        <p><span class="mono">Current gestational age:</span> <span id="ga">—</span></p>
        <p><span class="mono">Trimester:</span> <span id="trimester">—</span></p>
        <p><span class="mono">First trimester ends:</span> <span id="t1-end">—</span></p>
        <p><span class="mono">Second trimester ends:</span> <span id="t2-end">—</span></p>
      </div>
      <p class="disclaimer mono">Estimates only. Consult a healthcare provider for medical guidance.</p>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; max-width: 56ch; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .status.ready { color: var(--accent); }
  .privacy { font-size: 11px; color: var(--muted); margin: 0 0 1.5rem; letter-spacing: 0.02em; border-left: 2px solid var(--rule); padding-left: 0.75rem; }
  .lede { font-size: 0.9375rem; color: var(--muted); line-height: 1.6; margin: 0 0 1.5rem; }
  .calc-form { display: flex; flex-direction: column; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field label { font-size: 0.8125rem; font-weight: 500; color: var(--muted); }
  .field input {
    padding: 0.625rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.9375rem; outline: none;
  }
  .field input:focus { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in oklab, var(--accent) 20%, transparent); }
  .btn {
    align-self: flex-start; padding: 0.625rem 1.5rem;
    background: var(--ink); color: var(--paper); border: none;
    font-family: var(--font-display); font-size: 0.9375rem; font-weight: 500;
    cursor: pointer; transition: opacity 120ms;
  }
  .btn:hover { opacity: 0.85; }
  .err { color: var(--accent); font-size: 12px; margin: 0; min-height: 1em; }
  .result { margin-top: 2rem; border-top: 1px solid var(--rule); padding-top: 1.5rem; }
  .result.hidden { display: none; }
  .result-main { display: flex; flex-direction: column; gap: 0.25rem; margin-bottom: 1rem; }
  .result-label { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
  .result-value { font-family: var(--font-display); font-size: 2rem; color: var(--ink); line-height: 1.1; }
  .result-details p { font-size: 0.875rem; color: var(--muted); margin: 0 0 0.375rem; }
  .result-details .mono { color: var(--ink); }
  .disclaimer { font-size: 11px; color: var(--muted); margin: 1rem 0 0; }
</style>

<script>
  const form = document.getElementById('preg-form') as HTMLFormElement
  const errEl = document.getElementById('err')!
  const resultEl = document.getElementById('preg-result')!
  const dueDateEl = document.getElementById('due-date')!
  const conceptionEl = document.getElementById('conception')!
  const gaEl = document.getElementById('ga')!
  const trimesterEl = document.getElementById('trimester')!
  const t1End = document.getElementById('t1-end')!
  const t2End = document.getElementById('t2-end')!

  const fmt = (d: Date) => d.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })
  const addDays = (d: Date, n: number) => { const x = new Date(d); x.setDate(x.getDate() + n); return x }

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    errEl.textContent = ''
    const lmpStr = (document.getElementById('lmp') as HTMLInputElement).value
    const cycle = parseInt((document.getElementById('cycle') as HTMLInputElement).value, 10)
    if (!lmpStr) { errEl.textContent = 'Please pick the first day of your last period.'; return }
    if (!cycle || cycle < 20 || cycle > 45) { errEl.textContent = 'Cycle length must be 20–45 days.'; return }
    const lmp = new Date(lmpStr + 'T00:00:00')
    if (isNaN(lmp.getTime())) { errEl.textContent = 'Invalid date.'; return }
    const today = new Date(); today.setHours(0, 0, 0, 0)
    if (lmp > today) { errEl.textContent = 'LMP cannot be in the future.'; return }

    const cycleAdj = cycle - 28
    const due = addDays(lmp, 280 + cycleAdj)
    const conception = addDays(lmp, 14 + cycleAdj)
    const daysSinceLmp = Math.floor((today.getTime() - lmp.getTime()) / 86400000)
    const weeks = Math.floor(daysSinceLmp / 7)
    const extraDays = daysSinceLmp % 7

    let tri = '—'
    if (weeks < 0) tri = 'Not yet pregnant by LMP'
    else if (weeks < 13) tri = 'First trimester'
    else if (weeks < 27) tri = 'Second trimester'
    else if (weeks <= 42) tri = 'Third trimester'
    else tri = 'Past 42 weeks — consult provider'

    dueDateEl.textContent = fmt(due)
    conceptionEl.textContent = fmt(conception)
    gaEl.textContent = weeks >= 0 ? `${weeks} weeks, ${extraDays} days` : '—'
    trimesterEl.textContent = tri
    t1End.textContent = fmt(addDays(lmp, 7 * 13))
    t2End.textContent = fmt(addDays(lmp, 7 * 27))
    resultEl.classList.remove('hidden')
  })
</script>

---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="BMR / TDEE Calculator — Oriz Vitals" description="Calculate your Basal Metabolic Rate and Total Daily Energy Expenditure. Runs entirely in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">BMR / TDEE Calculator</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="privacy mono">All calculations run in your browser. Nothing is sent to any server.</p>

    <form class="calc-form" id="bmr-form" novalidate>
      <div class="field-row">
        <div class="field">
          <label for="age">Age (years)</label>
          <input type="number" id="age" min="10" max="120" step="1" placeholder="30" required />
        </div>
        <div class="field">
          <label for="sex">Sex</label>
          <select id="sex">
            <option value="male">Male</option>
            <option value="female">Female</option>
          </select>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label for="bmr-weight">Weight</label>
          <div class="input-group">
            <input type="number" id="bmr-weight" min="20" max="300" step="0.1" placeholder="70" required />
            <select id="bmr-weight-unit">
              <option value="kg" selected>kg</option>
              <option value="lbs">lbs</option>
            </select>
          </div>
        </div>
        <div class="field">
          <label for="bmr-height">Height</label>
          <div class="input-group">
            <input type="number" id="bmr-height" min="50" max="300" step="0.1" placeholder="175" required />
            <select id="bmr-height-unit">
              <option value="cm" selected>cm</option>
              <option value="in">in</option>
            </select>
          </div>
        </div>
      </div>
      <div class="field">
        <label for="activity">Activity level</label>
        <select id="activity">
          <option value="1.2">Sedentary (desk job, little/no exercise)</option>
          <option value="1.375">Lightly active (1–3 days/week)</option>
          <option value="1.55" selected>Moderately active (3–5 days/week)</option>
          <option value="1.725">Very active (6–7 days/week)</option>
          <option value="1.9">Extra active (physical job or 2x/day training)</option>
        </select>
      </div>
      <button type="submit" class="btn">Calculate</button>
    </form>

    <div class="result hidden" id="bmr-result" aria-live="polite">
      <div class="result-grid">
        <div class="result-card">
          <span class="result-label mono">BMR</span>
          <span class="result-value" id="bmr-value">—</span>
          <span class="result-unit mono">kcal/day</span>
          <p class="result-note">Calories at complete rest</p>
        </div>
        <div class="result-card accent">
          <span class="result-label mono">TDEE</span>
          <span class="result-value" id="tdee-value">—</span>
          <span class="result-unit mono">kcal/day</span>
          <p class="result-note">Maintenance calories</p>
        </div>
      </div>
      <div class="goals">
        <p class="goals-title mono">Calorie targets by goal:</p>
        <table class="goals-table">
          <tbody>
            <tr><td>Aggressive cut (−500 kcal)</td><td class="mono" id="goal-cut-500">—</td></tr>
            <tr><td>Moderate cut (−250 kcal)</td><td class="mono" id="goal-cut-250">—</td></tr>
            <tr><td>Maintenance</td><td class="mono" id="goal-maintain">—</td></tr>
            <tr><td>Moderate bulk (+250 kcal)</td><td class="mono" id="goal-bulk-250">—</td></tr>
            <tr><td>Aggressive bulk (+500 kcal)</td><td class="mono" id="goal-bulk-500">—</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; max-width: 56ch; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .status.ready { color: var(--accent); }
  .privacy { font-size: 11px; color: var(--muted); margin: 0 0 2rem; letter-spacing: 0.02em; border-left: 2px solid var(--rule); padding-left: 0.75rem; }
  .calc-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field label { font-size: 0.8125rem; font-weight: 500; color: var(--muted); }
  .field input, .field select {
    padding: 0.625rem 0.75rem; background: var(--paper-2);
    border: 1px solid var(--rule); color: var(--ink);
    font-family: var(--font-mono); font-size: 0.9375rem;
  }
  .field input:focus, .field select:focus { outline: none; border-color: var(--accent); }
  .input-group { display: flex; }
  .input-group input {
    flex: 1; padding: 0.625rem 0.75rem; background: var(--paper-2);
    border: 1px solid var(--rule); border-right: none; color: var(--ink);
    font-family: var(--font-mono); font-size: 0.9375rem; outline: none; min-width: 0;
  }
  .input-group input:focus { border-color: var(--accent); }
  .input-group select { padding: 0.625rem 0.5rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--muted); font-family: var(--font-mono); font-size: 0.8125rem; }
  .btn { align-self: flex-start; padding: 0.625rem 1.5rem; background: var(--ink); color: var(--paper); border: none; font-family: var(--font-display); font-size: 0.9375rem; font-weight: 500; cursor: pointer; transition: opacity 120ms; }
  .btn:hover { opacity: 0.85; }
  .result { margin-top: 2rem; border-top: 1px solid var(--rule); padding-top: 1.5rem; }
  .result.hidden { display: none; }
  .result-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem; }
  .result-card { padding: 1rem; background: var(--paper-2); border: 1px solid var(--rule); }
  .result-card.accent { border-color: var(--accent); }
  .result-label { display: block; font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.25rem; }
  .result-value { display: block; font-family: var(--font-mono); font-size: 2rem; color: var(--ink); line-height: 1; }
  .result-unit { display: block; font-size: 10px; color: var(--muted); margin-top: 0.25rem; }
  .result-note { font-size: 0.75rem; color: var(--muted); margin: 0.5rem 0 0; }
  .goals-title { font-size: 11px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 0.75rem; }
  .goals-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .goals-table td { padding: 0.4rem 0; border-bottom: 1px solid var(--rule); color: var(--ink); }
  .goals-table td:last-child { text-align: right; color: var(--accent); }
</style>

<script>
  const form = document.getElementById('bmr-form') as HTMLFormElement
  const resultEl = document.getElementById('bmr-result')!

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    const age = parseFloat((document.getElementById('age') as HTMLInputElement).value)
    const sex = (document.getElementById('sex') as HTMLSelectElement).value
    let weight = parseFloat((document.getElementById('bmr-weight') as HTMLInputElement).value)
    let height = parseFloat((document.getElementById('bmr-height') as HTMLInputElement).value)
    const weightUnit = (document.getElementById('bmr-weight-unit') as HTMLSelectElement).value
    const heightUnit = (document.getElementById('bmr-height-unit') as HTMLSelectElement).value
    const activity = parseFloat((document.getElementById('activity') as HTMLSelectElement).value)

    if (!age || !weight || !height) return

    if (weightUnit === 'lbs') weight = weight * 0.453592
    if (heightUnit === 'in') height = height * 2.54

    // Mifflin-St Jeor equation
    let bmr: number
    if (sex === 'male') {
      bmr = 10 * weight + 6.25 * height - 5 * age + 5
    } else {
      bmr = 10 * weight + 6.25 * height - 5 * age - 161
    }

    const tdee = bmr * activity

    document.getElementById('bmr-value')!.textContent = Math.round(bmr).toString()
    document.getElementById('tdee-value')!.textContent = Math.round(tdee).toString()
    document.getElementById('goal-cut-500')!.textContent = `${Math.round(tdee - 500)} kcal`
    document.getElementById('goal-cut-250')!.textContent = `${Math.round(tdee - 250)} kcal`
    document.getElementById('goal-maintain')!.textContent = `${Math.round(tdee)} kcal`
    document.getElementById('goal-bulk-250')!.textContent = `${Math.round(tdee + 250)} kcal`
    document.getElementById('goal-bulk-500')!.textContent = `${Math.round(tdee + 500)} kcal`

    resultEl.classList.remove('hidden')
  })
</script>

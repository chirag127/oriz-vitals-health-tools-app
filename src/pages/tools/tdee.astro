---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="TDEE Calculator — Oriz Vitals" description="Total Daily Energy Expenditure. Mifflin–St Jeor BMR multiplied by activity factor. Runs in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">TDEE Calculator</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="privacy mono">All calculations run in your browser. Nothing is sent to any server.</p>
    <p class="lede">Total Daily Energy Expenditure is your BMR (Mifflin–St Jeor) multiplied by an activity factor. Use it as a maintenance kcal anchor — eat under for deficit, over for surplus.</p>

    <form class="calc-form" id="form" novalidate>
      <div class="field-row">
        <div class="field">
          <label for="sex">Sex</label>
          <select id="sex"><option value="male">Male</option><option value="female">Female</option></select>
        </div>
        <div class="field">
          <label for="age">Age (years)</label>
          <input type="number" id="age" min="15" max="100" step="1" value="30" required />
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label for="weight">Weight (kg)</label>
          <input type="number" id="weight" min="30" max="300" step="0.1" value="70" required />
        </div>
        <div class="field">
          <label for="height">Height (cm)</label>
          <input type="number" id="height" min="100" max="250" step="0.1" value="175" required />
        </div>
      </div>
      <div class="field">
        <label for="activity">Activity level</label>
        <select id="activity">
          <option value="1.2">Sedentary — desk job, little exercise (×1.2)</option>
          <option value="1.375">Light — 1–3 sessions/wk (×1.375)</option>
          <option value="1.55" selected>Moderate — 3–5 sessions/wk (×1.55)</option>
          <option value="1.725">Heavy — 6–7 sessions/wk (×1.725)</option>
          <option value="1.9">Athlete — 2× daily training (×1.9)</option>
        </select>
      </div>
      <button type="submit" class="btn">Calculate TDEE</button>
    </form>

    <div class="result hidden" id="result" aria-live="polite">
      <div class="row"><span class="lab mono">BMR</span><span class="val mono" id="bmr">—</span><span class="unit">kcal/day</span></div>
      <div class="row primary"><span class="lab mono">TDEE</span><span class="val mono" id="tdee">—</span><span class="unit">kcal/day</span></div>
      <table>
        <thead><tr><th>Goal</th><th>kcal/day</th></tr></thead>
        <tbody>
          <tr><td>Aggressive cut (−20%)</td><td id="cut2">—</td></tr>
          <tr><td>Moderate cut (−10%)</td><td id="cut1">—</td></tr>
          <tr><td>Maintain</td><td id="maint">—</td></tr>
          <tr><td>Lean bulk (+10%)</td><td id="bulk1">—</td></tr>
          <tr><td>Bulk (+20%)</td><td id="bulk2">—</td></tr>
        </tbody>
      </table>
    </div>
    <p class="error hidden mono" id="err"></p>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; max-width: 56ch; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .status.ready { color: var(--accent); }
  .privacy { font-size: 11px; color: var(--muted); margin: 0 0 1rem; letter-spacing: 0.02em; border-left: 2px solid var(--rule); padding-left: 0.75rem; }
  .lede { font-size: 0.9375rem; color: var(--muted); line-height: 1.6; margin: 0 0 2rem; }
  .calc-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field label { font-size: 0.8125rem; font-weight: 500; color: var(--muted); }
  .field input, .field select { padding: 0.625rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.9375rem; outline: none; }
  .btn { align-self: flex-start; padding: 0.625rem 1.5rem; background: var(--ink); color: var(--paper); border: none; font-family: var(--font-display); font-size: 0.9375rem; font-weight: 500; cursor: pointer; }
  .btn:hover { opacity: 0.85; }
  .result { margin-top: 2rem; border-top: 1px solid var(--rule); padding-top: 1.5rem; }
  .result.hidden, .error.hidden { display: none; }
  .row { display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 0.5rem; }
  .row.primary { margin: 0.75rem 0 1.5rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--rule); }
  .lab { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; width: 4ch; }
  .val { font-family: var(--font-mono); font-size: 1.75rem; color: var(--ink); }
  .row.primary .val { font-size: 2.5rem; color: var(--accent); }
  .unit { font-size: 0.75rem; color: var(--muted); }
  table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 0.875rem; }
  th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--rule); }
  th { color: var(--muted); font-weight: 500; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; }
  .error { color: var(--accent); font-size: 12px; margin-top: 1rem; }
</style>

<script>
  const form = document.getElementById('form') as HTMLFormElement
  const result = document.getElementById('result')!
  const err = document.getElementById('err')!
  const $ = (id: string) => document.getElementById(id)!
  form.addEventListener('submit', (e) => {
    e.preventDefault()
    err.classList.add('hidden')
    const sex = ($('sex') as HTMLSelectElement).value
    const age = parseFloat(($('age') as HTMLInputElement).value)
    const w = parseFloat(($('weight') as HTMLInputElement).value)
    const h = parseFloat(($('height') as HTMLInputElement).value)
    const a = parseFloat(($('activity') as HTMLSelectElement).value)
    if (!age || !w || !h) { err.textContent = 'Please fill every field.'; err.classList.remove('hidden'); return }
    const bmr = 10 * w + 6.25 * h - 5 * age + (sex === 'male' ? 5 : -161)
    const tdee = bmr * a
    $('bmr').textContent = Math.round(bmr).toString()
    $('tdee').textContent = Math.round(tdee).toString()
    $('cut2').textContent = Math.round(tdee * 0.8).toString()
    $('cut1').textContent = Math.round(tdee * 0.9).toString()
    $('maint').textContent = Math.round(tdee).toString()
    $('bulk1').textContent = Math.round(tdee * 1.1).toString()
    $('bulk2').textContent = Math.round(tdee * 1.2).toString()
    result.classList.remove('hidden')
  })
</script>

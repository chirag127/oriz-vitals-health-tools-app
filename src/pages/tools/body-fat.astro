---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Body Fat % Estimator — Oriz Vitals" description="Estimate body fat percentage using the U.S. Navy method with body measurements. Runs entirely in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Body Fat % Estimator</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="privacy mono">All calculations run in your browser. Nothing is sent to any server.</p>
    <p class="method-note">Uses the <strong>U.S. Navy circumference method</strong>. Measurements should be taken in the morning, at the widest point, without sucking in.</p>

    <form class="calc-form" id="bf-form" novalidate>
      <div class="field-row">
        <div class="field">
          <label for="bf-sex">Sex</label>
          <select id="bf-sex">
            <option value="male">Male</option>
            <option value="female">Female</option>
          </select>
        </div>
        <div class="field">
          <label for="bf-unit">Unit</label>
          <select id="bf-unit">
            <option value="cm" selected>cm</option>
            <option value="in">inches</option>
          </select>
        </div>
      </div>
      <div class="field">
        <label for="bf-height">Height</label>
        <input type="number" id="bf-height" min="50" max="300" step="0.1" placeholder="175" required />
      </div>
      <div class="field">
        <label for="bf-waist">Waist circumference <span class="hint-inline">(at navel for men, smallest point for women)</span></label>
        <input type="number" id="bf-waist" min="40" max="200" step="0.1" placeholder="80" required />
      </div>
      <div class="field">
        <label for="bf-neck">Neck circumference <span class="hint-inline">(below larynx, slanting slightly downward)</span></label>
        <input type="number" id="bf-neck" min="20" max="80" step="0.1" placeholder="38" required />
      </div>
      <div class="field" id="hip-field" style="display:none">
        <label for="bf-hip">Hip circumference <span class="hint-inline">(widest point — women only)</span></label>
        <input type="number" id="bf-hip" min="50" max="200" step="0.1" placeholder="95" />
      </div>
      <button type="submit" class="btn">Calculate</button>
    </form>

    <div class="result hidden" id="bf-result" aria-live="polite">
      <div class="result-main">
        <span class="result-label mono">Body fat</span>
        <span class="result-value" id="bf-value">—</span>
        <span class="result-unit mono">%</span>
        <span class="result-category" id="bf-category">—</span>
      </div>
      <p id="bf-lean-mass" class="result-detail"></p>
      <div class="bf-scale">
        <p class="scale-title mono">Reference ranges (by sex):</p>
        <div class="scale-rows" id="bf-scale-rows"></div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; max-width: 56ch; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .status.ready { color: var(--accent); }
  .privacy { font-size: 11px; color: var(--muted); margin: 0 0 0.5rem; letter-spacing: 0.02em; border-left: 2px solid var(--rule); padding-left: 0.75rem; }
  .method-note { font-size: 0.875rem; color: var(--muted); margin: 0 0 1.5rem; }
  .calc-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field label { font-size: 0.8125rem; font-weight: 500; color: var(--muted); }
  .hint-inline { font-size: 10px; font-weight: 400; color: var(--muted); font-family: var(--font-mono); }
  .field input, .field select { padding: 0.625rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.9375rem; max-width: 200px; }
  .field input:focus, .field select:focus { outline: none; border-color: var(--accent); }
  .btn { align-self: flex-start; padding: 0.625rem 1.5rem; background: var(--ink); color: var(--paper); border: none; font-family: var(--font-display); font-size: 0.9375rem; font-weight: 500; cursor: pointer; transition: opacity 120ms; }
  .btn:hover { opacity: 0.85; }
  .result { margin-top: 2rem; border-top: 1px solid var(--rule); padding-top: 1.5rem; }
  .result.hidden { display: none; }
  .result-main { display: flex; align-items: baseline; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .result-label { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
  .result-value { font-family: var(--font-mono); font-size: 3rem; color: var(--ink); line-height: 1; }
  .result-unit { font-size: 0.875rem; color: var(--muted); }
  .result-category { font-size: 1.125rem; font-weight: 500; }
  .result-detail { font-size: 0.875rem; color: var(--muted); margin: 0 0 1.5rem; }
  .scale-title { font-size: 11px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 0.75rem; }
  .scale-row { display: flex; align-items: center; gap: 0.75rem; padding: 0.375rem 0; border-bottom: 1px solid var(--rule); font-size: 0.8125rem; }
  .scale-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .scale-cat { flex: 1; color: var(--muted); }
  .scale-range { font-family: var(--font-mono); color: var(--ink); font-size: 0.8125rem; }
  .scale-row.current { background: color-mix(in oklab, var(--accent) 10%, transparent); }
  .scale-row.current .scale-cat { color: var(--ink); font-weight: 500; }
</style>

<script>
  const sexSelect = document.getElementById('bf-sex') as HTMLSelectElement
  const hipField = document.getElementById('hip-field') as HTMLDivElement

  sexSelect.addEventListener('change', () => {
    hipField.style.display = sexSelect.value === 'female' ? '' : 'none'
    if (sexSelect.value === 'female') {
      (document.getElementById('bf-hip') as HTMLInputElement).required = true
    } else {
      (document.getElementById('bf-hip') as HTMLInputElement).required = false
    }
  })

  const MALE_RANGES = [
    { label: 'Essential fat', min: 2, max: 5, color: '#7dd3fc' },
    { label: 'Athletes', min: 6, max: 13, color: '#4ade80' },
    { label: 'Fitness', min: 14, max: 17, color: '#a3e635' },
    { label: 'Average', min: 18, max: 24, color: '#facc15' },
    { label: 'Obese', min: 25, max: 100, color: '#f87171' },
  ]
  const FEMALE_RANGES = [
    { label: 'Essential fat', min: 10, max: 13, color: '#7dd3fc' },
    { label: 'Athletes', min: 14, max: 20, color: '#4ade80' },
    { label: 'Fitness', min: 21, max: 24, color: '#a3e635' },
    { label: 'Average', min: 25, max: 31, color: '#facc15' },
    { label: 'Obese', min: 32, max: 100, color: '#f87171' },
  ]

  const form = document.getElementById('bf-form') as HTMLFormElement
  const resultEl = document.getElementById('bf-result')!

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    const sex = sexSelect.value
    const unit = (document.getElementById('bf-unit') as HTMLSelectElement).value
    let height = parseFloat((document.getElementById('bf-height') as HTMLInputElement).value)
    let waist = parseFloat((document.getElementById('bf-waist') as HTMLInputElement).value)
    let neck = parseFloat((document.getElementById('bf-neck') as HTMLInputElement).value)
    let hip = parseFloat((document.getElementById('bf-hip') as HTMLInputElement).value)

    if (!height || !waist || !neck) return

    // Convert inches to cm if needed
    if (unit === 'in') {
      height *= 2.54; waist *= 2.54; neck *= 2.54
      if (hip) hip *= 2.54
    }

    let bf: number
    if (sex === 'male') {
      bf = 495 / (1.0324 - 0.19077 * Math.log10(waist - neck) + 0.15456 * Math.log10(height)) - 450
    } else {
      if (!hip) { alert('Hip measurement required for female calculation.'); return }
      bf = 495 / (1.29579 - 0.35004 * Math.log10(waist + hip - neck) + 0.22100 * Math.log10(height)) - 450
    }

    bf = Math.max(3, Math.min(60, bf))

    document.getElementById('bf-value')!.textContent = bf.toFixed(1)

    const ranges = sex === 'male' ? MALE_RANGES : FEMALE_RANGES
    const currentRange = ranges.find(r => bf >= r.min && bf <= r.max) ?? ranges[ranges.length - 1]

    const catEl = document.getElementById('bf-category')!
    catEl.textContent = currentRange.label
    catEl.style.color = currentRange.color

    const scaleEl = document.getElementById('bf-scale-rows')!
    scaleEl.innerHTML = ranges.map(r => {
      const isCurrent = r.label === currentRange.label
      return `<div class="scale-row${isCurrent ? ' current' : ''}">
        <span class="scale-dot" style="background:${r.color}"></span>
        <span class="scale-cat">${r.label}</span>
        <span class="scale-range">${r.min}–${r.max === 100 ? '35+' : r.max}%</span>
        ${isCurrent ? '<span style="font-size:10px;color:var(--accent);font-family:var(--font-mono)">← you</span>' : ''}
      </div>`
    }).join('')

    resultEl.classList.remove('hidden')
  })
</script>

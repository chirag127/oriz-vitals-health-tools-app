---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Step Calculator — Oriz Vitals" description="Convert steps to distance and calories, or work out how many steps a given distance is. Runs entirely in your browser.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Step Calculator</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="privacy mono">All calculations run in your browser. Nothing is sent to any server.</p>
    <p class="lede">Estimate stride length from your height, then convert between steps, distance, and calories burned.</p>

    <form class="calc-form" id="step-form" novalidate>
      <div class="field-row">
        <div class="field">
          <label for="height">Height</label>
          <div class="input-group">
            <input type="number" id="height" name="height" min="120" max="230" step="0.1" placeholder="170" required />
            <select id="height-unit" name="height-unit">
              <option value="cm" selected>cm</option>
              <option value="in">in</option>
            </select>
          </div>
        </div>
        <div class="field">
          <label for="weight">Weight</label>
          <div class="input-group">
            <input type="number" id="weight" name="weight" min="20" max="300" step="0.1" placeholder="70" required />
            <select id="weight-unit" name="weight-unit">
              <option value="kg" selected>kg</option>
              <option value="lbs">lbs</option>
            </select>
          </div>
        </div>
      </div>

      <div class="field">
        <label for="pace">Walking pace</label>
        <select id="pace" name="pace">
          <option value="slow">Slow stroll (~3 km/h)</option>
          <option value="normal" selected>Normal walk (~5 km/h)</option>
          <option value="brisk">Brisk walk (~6.5 km/h)</option>
          <option value="run">Light jog (~8 km/h)</option>
        </select>
      </div>

      <div class="field-row">
        <div class="field">
          <label for="steps">Steps</label>
          <input type="number" id="steps" min="0" step="1" placeholder="10000" />
        </div>
        <div class="field">
          <label for="distance">— or — distance (km)</label>
          <input type="number" id="distance" min="0" step="0.01" placeholder="8" />
        </div>
      </div>
      <button type="submit" class="btn">Calculate</button>
      <p class="err mono" id="err" role="alert"></p>
    </form>

    <div class="result hidden" id="step-result" aria-live="polite">
      <div class="grid">
        <div class="metric">
          <span class="metric-label mono">Stride length</span>
          <span class="metric-value" id="stride">—</span>
        </div>
        <div class="metric">
          <span class="metric-label mono">Steps</span>
          <span class="metric-value" id="out-steps">—</span>
        </div>
        <div class="metric">
          <span class="metric-label mono">Distance</span>
          <span class="metric-value" id="out-distance">—</span>
        </div>
        <div class="metric">
          <span class="metric-label mono">Calories</span>
          <span class="metric-value" id="out-cals">—</span>
        </div>
        <div class="metric">
          <span class="metric-label mono">Time</span>
          <span class="metric-value" id="out-time">—</span>
        </div>
      </div>
      <p class="disclaimer mono">Stride ≈ height × 0.414 (women) / 0.415 (men); we use 0.4145 as a unisex estimate. Calorie estimate uses MET × weight × hours; real-world variance is high.</p>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; max-width: 60ch; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .status.ready { color: var(--accent); }
  .privacy { font-size: 11px; color: var(--muted); margin: 0 0 1.5rem; letter-spacing: 0.02em; border-left: 2px solid var(--rule); padding-left: 0.75rem; }
  .lede { font-size: 0.9375rem; color: var(--muted); line-height: 1.6; margin: 0 0 1.5rem; }
  .calc-form { display: flex; flex-direction: column; gap: 1rem; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field label { font-size: 0.8125rem; font-weight: 500; color: var(--muted); }
  .field input, .field select {
    padding: 0.625rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.9375rem; outline: none;
  }
  .field input:focus, .field select:focus { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in oklab, var(--accent) 20%, transparent); }
  .input-group { display: flex; gap: 0; }
  .input-group input { flex: 1; border-right: none; min-width: 0; }
  .input-group select { padding: 0.625rem 0.5rem; color: var(--muted); font-size: 0.8125rem; cursor: pointer; }
  .btn {
    align-self: flex-start; padding: 0.625rem 1.5rem;
    background: var(--ink); color: var(--paper); border: none;
    font-family: var(--font-display); font-size: 0.9375rem; font-weight: 500;
    cursor: pointer; transition: opacity 120ms;
  }
  .btn:hover { opacity: 0.85; }
  .err { color: var(--accent); font-size: 12px; margin: 0; min-height: 1em; }
  .result { margin-top: 2rem; border-top: 1px solid var(--rule); padding-top: 1.5rem; }
  .result.hidden { display: none; }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; }
  .metric { display: flex; flex-direction: column; gap: 0.25rem; padding: 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); }
  .metric-label { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
  .metric-value { font-family: var(--font-mono); font-size: 1.25rem; color: var(--ink); line-height: 1.1; }
  .disclaimer { font-size: 11px; color: var(--muted); margin: 1rem 0 0; }
</style>

<script>
  const form = document.getElementById('step-form') as HTMLFormElement
  const errEl = document.getElementById('err')!
  const resultEl = document.getElementById('step-result')!
  const strideEl = document.getElementById('stride')!
  const outSteps = document.getElementById('out-steps')!
  const outDistance = document.getElementById('out-distance')!
  const outCals = document.getElementById('out-cals')!
  const outTime = document.getElementById('out-time')!

  // MET values for walking/jogging activities
  const MET: Record<string, { met: number; kmh: number }> = {
    slow:   { met: 2.8, kmh: 3.0 },
    normal: { met: 3.5, kmh: 5.0 },
    brisk:  { met: 5.0, kmh: 6.5 },
    run:    { met: 8.3, kmh: 8.0 },
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    errEl.textContent = ''
    const heightInput = parseFloat((document.getElementById('height') as HTMLInputElement).value)
    const weightInput = parseFloat((document.getElementById('weight') as HTMLInputElement).value)
    const hUnit = (document.getElementById('height-unit') as HTMLSelectElement).value
    const wUnit = (document.getElementById('weight-unit') as HTMLSelectElement).value
    const pace = (document.getElementById('pace') as HTMLSelectElement).value
    const stepsRaw = (document.getElementById('steps') as HTMLInputElement).value
    const distRaw = (document.getElementById('distance') as HTMLInputElement).value

    if (!heightInput || !weightInput) { errEl.textContent = 'Enter height and weight.'; return }
    if (!stepsRaw && !distRaw) { errEl.textContent = 'Enter either steps or distance.'; return }

    const heightCm = hUnit === 'in' ? heightInput * 2.54 : heightInput
    const weightKg = wUnit === 'lbs' ? weightInput * 0.453592 : weightInput
    const strideM = (heightCm * 0.4145) / 100
    const { met, kmh } = MET[pace]

    let steps: number, distanceKm: number
    if (stepsRaw) {
      steps = parseFloat(stepsRaw)
      distanceKm = (steps * strideM) / 1000
    } else {
      distanceKm = parseFloat(distRaw)
      steps = Math.round((distanceKm * 1000) / strideM)
    }
    if (!isFinite(steps) || !isFinite(distanceKm) || steps < 0 || distanceKm < 0) {
      errEl.textContent = 'Enter a positive number.'; return
    }

    const hours = distanceKm / kmh
    const calories = met * weightKg * hours
    const totalMin = hours * 60
    const mm = Math.floor(totalMin)
    const ss = Math.round((totalMin - mm) * 60)

    strideEl.textContent = `${(strideM * 100).toFixed(1)} cm`
    outSteps.textContent = steps.toLocaleString()
    outDistance.textContent = `${distanceKm.toFixed(2)} km · ${(distanceKm * 0.621371).toFixed(2)} mi`
    outCals.textContent = `${Math.round(calories)} kcal`
    outTime.textContent = `${mm}m ${ss}s`
    resultEl.classList.remove('hidden')
  })
</script>

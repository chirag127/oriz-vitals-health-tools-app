---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Period Tracker (private) — Oriz Vitals" description="Track your menstrual cycle privately. Data stays on your device — never sent to any server.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Period Tracker (private)</h1>
    <p class="status mono ready">ready · v0.1</p>
    <p class="privacy mono">Logs are stored only in this browser (localStorage). Nothing leaves your device. Clear it any time.</p>

    <form class="calc-form" id="log-form" novalidate>
      <div class="field-row">
        <div class="field">
          <label for="start">Period start date</label>
          <input type="date" id="start" name="start" required />
        </div>
        <div class="field">
          <label for="length">Bleeding days</label>
          <input type="number" id="length" name="length" min="1" max="15" step="1" value="5" />
        </div>
      </div>
      <div class="row">
        <button type="submit" class="btn">Log period</button>
        <button type="button" class="btn ghost" id="clear-btn">Clear all data</button>
      </div>
      <p class="err mono" id="err" role="alert"></p>
    </form>

    <section class="result" aria-live="polite">
      <h2 class="h2">Predictions</h2>
      <div class="result-details">
        <p><span class="mono">Average cycle length:</span> <span id="avg-cycle">—</span></p>
        <p><span class="mono">Last period:</span> <span id="last">—</span></p>
        <p><span class="mono">Next period (est):</span> <span id="next-period">—</span></p>
        <p><span class="mono">Estimated ovulation:</span> <span id="next-ovu">—</span></p>
        <p><span class="mono">Days until next period:</span> <span id="days-until">—</span></p>
      </div>

      <h2 class="h2">Log history</h2>
      <ul class="history mono" id="history"></ul>
    </section>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; max-width: 60ch; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .h2 { font-family: var(--font-display); font-weight: 600; font-size: 1.125rem; margin: 1.5rem 0 0.5rem; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .status.ready { color: var(--accent); }
  .privacy { font-size: 11px; color: var(--muted); margin: 0 0 1.5rem; letter-spacing: 0.02em; border-left: 2px solid var(--rule); padding-left: 0.75rem; }
  .calc-form { display: flex; flex-direction: column; gap: 1rem; }
  .field-row { display: grid; grid-template-columns: 1fr 140px; gap: 1rem; }
  .field { display: flex; flex-direction: column; gap: 0.375rem; }
  .field label { font-size: 0.8125rem; font-weight: 500; color: var(--muted); }
  .field input {
    padding: 0.625rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule);
    color: var(--ink); font-family: var(--font-mono); font-size: 0.9375rem; outline: none;
  }
  .field input:focus { border-color: var(--accent); box-shadow: 0 0 0 2px color-mix(in oklab, var(--accent) 20%, transparent); }
  .row { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .btn {
    padding: 0.625rem 1.5rem;
    background: var(--ink); color: var(--paper); border: none;
    font-family: var(--font-display); font-size: 0.9375rem; font-weight: 500;
    cursor: pointer; transition: opacity 120ms;
  }
  .btn:hover { opacity: 0.85; }
  .btn.ghost { background: transparent; color: var(--muted); border: 1px solid var(--rule); }
  .btn.ghost:hover { color: var(--ink); border-color: var(--ink); }
  .err { color: var(--accent); font-size: 12px; margin: 0; min-height: 1em; }
  .result { margin-top: 2rem; border-top: 1px solid var(--rule); padding-top: 1.5rem; }
  .result-details p { font-size: 0.875rem; color: var(--muted); margin: 0 0 0.375rem; }
  .result-details .mono { color: var(--ink); }
  .history { list-style: none; padding: 0; margin: 0; font-size: 0.8125rem; color: var(--muted); }
  .history li { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 0; border-bottom: 1px solid var(--rule); gap: 1rem; }
  .history button { background: transparent; border: none; color: var(--accent); font-family: var(--font-mono); font-size: 11px; cursor: pointer; }
  .history button:hover { text-decoration: underline; }
  .empty { font-style: italic; }
</style>

<script>
  type Log = { start: string; length: number }
  const KEY = 'oriz-vitals-period-logs'
  const form = document.getElementById('log-form') as HTMLFormElement
  const errEl = document.getElementById('err')!
  const avgCycleEl = document.getElementById('avg-cycle')!
  const lastEl = document.getElementById('last')!
  const nextPeriodEl = document.getElementById('next-period')!
  const nextOvuEl = document.getElementById('next-ovu')!
  const daysUntilEl = document.getElementById('days-until')!
  const historyEl = document.getElementById('history')!
  const clearBtn = document.getElementById('clear-btn')!

  const fmt = (d: Date) => d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' })
  const addDays = (d: Date, n: number) => { const x = new Date(d); x.setDate(x.getDate() + n); return x }

  function read(): Log[] {
    try {
      const raw = localStorage.getItem(KEY)
      if (!raw) return []
      const parsed = JSON.parse(raw)
      return Array.isArray(parsed) ? parsed : []
    } catch { return [] }
  }

  function write(logs: Log[]) {
    try { localStorage.setItem(KEY, JSON.stringify(logs)) } catch {}
  }

  function render() {
    const logs = read().slice().sort((a, b) => a.start.localeCompare(b.start))
    historyEl.innerHTML = ''
    if (logs.length === 0) {
      const li = document.createElement('li'); li.className = 'empty'; li.textContent = 'No entries yet.'; historyEl.appendChild(li)
      avgCycleEl.textContent = '—'; lastEl.textContent = '—'; nextPeriodEl.textContent = '—'; nextOvuEl.textContent = '—'; daysUntilEl.textContent = '—'
      return
    }
    for (const log of logs) {
      const li = document.createElement('li')
      const span = document.createElement('span')
      span.textContent = `${log.start} · ${log.length}d`
      const btn = document.createElement('button')
      btn.type = 'button'; btn.textContent = 'remove'
      btn.addEventListener('click', () => {
        write(read().filter(l => !(l.start === log.start && l.length === log.length)))
        render()
      })
      li.appendChild(span); li.appendChild(btn); historyEl.appendChild(li)
    }

    const dates = logs.map(l => new Date(l.start + 'T00:00:00'))
    let avg = 28
    if (dates.length >= 2) {
      let sum = 0
      for (let i = 1; i < dates.length; i++) sum += (dates[i].getTime() - dates[i - 1].getTime()) / 86400000
      avg = Math.round(sum / (dates.length - 1))
      if (avg < 20 || avg > 45) avg = 28
    }
    const last = dates[dates.length - 1]
    const next = addDays(last, avg)
    const ovu = addDays(last, avg - 14)
    const today = new Date(); today.setHours(0, 0, 0, 0)
    const daysUntil = Math.round((next.getTime() - today.getTime()) / 86400000)

    avgCycleEl.textContent = dates.length >= 2 ? `${avg} days` : 'need 2+ logs (using 28d)'
    lastEl.textContent = fmt(last)
    nextPeriodEl.textContent = fmt(next)
    nextOvuEl.textContent = fmt(ovu)
    daysUntilEl.textContent = daysUntil >= 0 ? `${daysUntil} days` : `overdue by ${-daysUntil} days`
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault()
    errEl.textContent = ''
    const start = (document.getElementById('start') as HTMLInputElement).value
    const length = parseInt((document.getElementById('length') as HTMLInputElement).value, 10) || 5
    if (!start) { errEl.textContent = 'Pick a start date.'; return }
    const logs = read()
    if (logs.some(l => l.start === start)) { errEl.textContent = 'A log already exists for that date.'; return }
    logs.push({ start, length })
    write(logs)
    form.reset()
    ;(document.getElementById('length') as HTMLInputElement).value = '5'
    render()
  })

  clearBtn.addEventListener('click', () => {
    if (confirm('Delete all period logs from this browser? This cannot be undone.')) {
      try { localStorage.removeItem(KEY) } catch {}
      render()
    }
  })

  render()
</script>
